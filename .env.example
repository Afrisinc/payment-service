NODE_ENV=production
PORT=3400
HOST=0.0.0.0
LOG_LEVEL=info

DATABASE_URL=postgresql://dbuser:password@localhost:5432/afrisinc_pay_db

# For Docker Compose
DB_USER=dbuser
DB_PASSWORD=password

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin API key — used to provision merchants (min 32 chars, generate with: openssl rand -hex 32)
ADMIN_API_KEY=

# Webhook callbacks are delivered to each merchant's configured webhookUrl
# using HMAC-SHA256 signing with their webhookSecret — no env vars needed.

FRONTEND_URL=https://afrisinc.com

# Swagger/OpenAPI Documentation
ENABLE_SWAGGER=false
API_BASE_URL=*********************
PAYPACK_URL==*********************
PAYPACK_CLIENT_ID==*********************
PAYPACK_CLIENT_SECRET==*********************